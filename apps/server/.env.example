# Application environment sample
NODE_ENV=development
HOST=0.0.0.0
PORT=5000

# Optional: where to load .env files from (nhr-style)
# If you run the server from the repo root but keep env files inside apps/server,
# set this to: D:\Project\blessedtourszim\apps\server
# BTS_ENV_ROOT=

# MongoDB connection string (Compass)
MONGODB_URI=mongodb://127.0.0.1:27017/blessedtourszim
MONGODB_DB_NAME=blessedtourszim

# JWT
# Use a long random string in production (min 16 chars).
JWT_SECRET=change-me-with-a-long-random-string

# Platform commission (basis points). Example: 600 = 6%
COMMISSION_BPS=600
